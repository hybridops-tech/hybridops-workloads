{
  "name": "@hybridops/keycloak-theme",
  "version": "0.1.0",
  "private": true,
  "description": "HybridOps Keycloak login theme built with Keycloakify.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "update-kc-gen": "keycloakify update-kc-gen",
    "build-keycloak-theme": "npm run build && keycloakify build && node ./scripts/finalize-theme-jar.cjs",
    "build-theme": "./scripts/build-keycloak-theme.sh"
  },
  "dependencies": {
    "keycloakify": "^11.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  }
}
